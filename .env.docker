# ==========================================================
# Article Check — Docker 部署环境变量模板
# 根据 PPT 规范: API Key 通过环境变量注入，不硬编码
# 复制为 .env 后填入真实值:
#   cp .env.docker .env
# ==========================================================

# ─── AI Provider（平台部署默认走 Dify）──────────────────
ARTICLE_CHECK_AI_PROVIDER=dify

# ─── Dify API（必填）─────────────────────────────────────
# 自托管 Dify 示例: http://host.docker.internal/v1
# SaaS Dify 示例: https://api.dify.ai/v1
DIFY_BASE_URL=http://host.docker.internal/v1
DIFY_API_KEY=app-your-dify-api-key-here

# Dify 应用类型: chat 或 workflow
DIFY_APP_TYPE=chat

# blocking 更适合当前后端代理模式
DIFY_RESPONSE_MODE=blocking

# 若 Dify 使用 workflow，可指定接收 query 的输入变量名
DIFY_WORKFLOW_QUERY_KEY=query

# Dify 应用的固定 inputs(JSON 字符串)
DIFY_INPUTS_JSON={}

# ─── DeepSeek API（可选兜底）─────────────────────────────
DEEPSEEK_API_KEY=

# ─── Nginx 端口 ──────────────────────────────────────────
# PPT 规范: 宿主机 80(3000) 端口映射容器内 web 服务端口
# 建议 3000 避免与已有服务冲突
NGINX_PORT=3000

# ─── 可选: 搜索 API ──────────────────────────────────────
# 从 https://serper.dev 获取
SERPER_API_KEY=

# ─── 其他配置 ────────────────────────────────────────────
# TZ=Asia/Shanghai
